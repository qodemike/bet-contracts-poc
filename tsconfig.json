{
  "compilerOptions": {
    "module": "esnext",
    "target": "es2020",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "paths": {
      "@contracts/*": ["./contracts/*"],
      "@libs/*": ["./libs/*"],
      "@generated/*": ["./libs/generated/*"]
    }
  },
}
